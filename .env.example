# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram Chat ID (run /start on the bot to register it automatically)
# Or get it from https://t.me/userinfobot
TELEGRAM_CHAT_ID=your_chat_id_here

# Google Gemini API Key (free) from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Google Calendar credentials file path (default: credentials.json)
# GOOGLE_CREDENTIALS_FILE=credentials.json
